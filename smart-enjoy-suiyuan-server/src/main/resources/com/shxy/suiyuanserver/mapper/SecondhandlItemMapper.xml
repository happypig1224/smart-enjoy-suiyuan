<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shxy.suiyuanserver.mapper.SecondhandItemMapper">

    <resultMap id="SecondhandItemVOResultMap" type="com.shxy.suiyuanentity.vo.SecondhandItemVO">
        <id property="id" column="item_id" />
        <result property="sellerId" column="seller_id" />
        <result property="sellerNickName" column="nick_name" />
        <result property="sellerAvatar" column="avatar" />
        <result property="sellerPhone" column="seller_phone" />
        <result property="title" column="title" />
        <result property="description" column="description" />
        <result property="category" column="category" />
        <result property="price" column="price" />
        <result property="originalPrice" column="original_price" />
        <result property="conditionLevel" column="condition_level" />
        <result property="images" column="images" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler" javaType="java.util.List" />
        <result property="contactPhone" column="contact_phone" />
        <result property="contactWechat" column="contact_wechat" />
        <result property="viewCount" column="view_count" />
        <result property="favoriteCount" column="favorite_count" />
        <result property="status" column="status" />
        <result property="tradeLocation" column="trade_location" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <select id="selectSecondhandItemListWithUser" parameterType="map" resultMap="SecondhandItemVOResultMap">
        SELECT
        si.id as item_id,
        si.seller_id,
        si.title,
        si.description,
        si.category,
        si.price,
        si.original_price,
        si.condition_level,
        si.images,
        si.contact_phone,
        si.contact_wechat,
        si.view_count,
        si.favorite_count,
        si.status,
        si.trade_location,
        si.create_time,
        si.update_time,
        u.nick_name,
        u.avatar,
        u.phone as seller_phone
        FROM secondhand_item si
        LEFT JOIN user u ON si.seller_id = u.id
        <where>
            si.is_deleted = 0
            <if test="category != null and category != 'all' and category != ''">
                AND si.category = #{category}
            </if>
            <if test="status != null">
                AND si.status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (si.title LIKE CONCAT('%', #{keyword}, '%') OR si.description LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY
        <choose>
            <when test="orderBy == 'hottest'">si.view_count DESC</when>
            <when test="orderBy == 'price_asc'">si.price ASC</when>
            <when test="orderBy == 'price_desc'">si.price DESC</when>
            <otherwise>si.create_time DESC</otherwise>
        </choose>
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="selectSecondhandItemCount" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM secondhand_item si
        <where>
            si.is_deleted = 0
            <if test="category != null and category != 'all' and category != ''">
                AND si.category = #{category}
            </if>
            <if test="status != null">
                AND si.status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (si.title LIKE CONCAT('%', #{keyword}, '%') OR si.description LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
    </select>
</mapper>
