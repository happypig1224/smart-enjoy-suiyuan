<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shxy.suiyuanserver.mapper.CommentMapper">

    <resultMap id="BaseResultMap" type="com.shxy.suiyuanentity.entity.Comment">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="content" column="content" />
        <result property="postId" column="post_id" />
        <result property="resourceId" column="resource_id" />
        <result property="parentId" column="parent_id" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="isDeleted" column="is_deleted" />
    </resultMap>

    <resultMap id="CommentVOResultMap" type="com.shxy.suiyuanentity.vo.CommentVO">
        <id property="id" column="comment_id" />
        <result property="userId" column="user_id" />
        <result property="userNickName" column="nick_name" />
        <result property="userAvatar" column="avatar" />
        <result property="content" column="content" />
        <result property="postId" column="post_id" />
        <result property="resourceId" column="resource_id" />
        <result property="parentId" column="parent_id" />
        <result property="createTime" column="create_time" />
        <result property="replyToUserId" column="reply_to_user_id" />
        <result property="replyToUserNickName" column="reply_to_user_nick_name" />
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,content,post_id,resource_id,parent_id,
        create_time,update_time,is_deleted
    </sql>

    <update id="updateIsDelete">
        update comment set is_deleted = 1 where id = #{id}
    </update>

    <select id="selectCommentListWithUser" resultMap="CommentVOResultMap">
        SELECT
        c.id as comment_id,
        c.user_id,
        c.content,
        c.post_id,
        c.resource_id,
        c.parent_id,
        c.create_time,
        u.nick_name,
        u.avatar,
        IF(c.parent_id IS NOT NULL AND c.parent_id > 0, p.user_id, NULL) as reply_to_user_id,
        IF(c.parent_id IS NOT NULL AND c.parent_id > 0, u2.nick_name, NULL) as reply_to_user_nick_name
        FROM comment c
        LEFT JOIN user u ON c.user_id = u.id
        LEFT JOIN comment p ON c.parent_id = p.id
        LEFT JOIN user u2 ON p.user_id = u2.id
        <where>
            c.is_deleted = 0
            <if test="postId != null">
                AND c.post_id = #{postId}
            </if>
            <if test="resourceId != null">
                AND c.resource_id = #{resourceId}
            </if>
        </where>
        ORDER BY c.create_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="selectCommentCount" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM comment
        <where>
            is_deleted = 0
            <if test="postId != null">
                AND post_id = #{postId}
            </if>
            <if test="resourceId != null">
                AND resource_id = #{resourceId}
            </if>
        </where>
    </select>
</mapper>
